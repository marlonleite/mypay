#!/usr/bin/env bash
# Runs after refs are negotiated; stdin lists pushed refs (see git help hooks).
# SKIP_NATIVE_INSTALL_ON_PUSH=1 or git push --no-verify skips install.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

updates_main=false
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${remote_ref:-}" != 'refs/heads/main' ]]; then
    continue
  fi
  if [[ "${local_sha:-}" == '0000000000000000000000000000000000000000' ]]; then
    continue
  fi
  updates_main=true
  break
done

if [[ "$updates_main" != true ]]; then
  exit 0
fi

if [[ "${SKIP_NATIVE_INSTALL_ON_PUSH:-}" == 1 ]]; then
  echo "[pre-push] SKIP_NATIVE_INSTALL_ON_PUSH=1 — Android install skipped." >&2
  exit 0
fi

hook_log() {
  echo "[pre-push] $*" >&2
}

hook_log 'push updates origin/main → checking Android installer'

if ! command -v adb >/dev/null 2>&1; then
  hook_log 'adb not in PATH — skipping native:install'
  exit 0
fi

adb devices >&2 || true

device_count="$(adb devices 2>/dev/null | awk '/\tdevice$/ { c++ } END { print c + 0 }')"
if [[ "$device_count" -lt 1 ]]; then
  hook_log 'no device in adb (need status device) — skipping native:install'
  exit 0
fi

hook_log "detected adb device count=${device_count} — running npm run native:install"
npm run native:install

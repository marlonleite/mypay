{
  "name": "mypay",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:proxy": "node scripts/proxy-server.js",
    "dev:full": "node scripts/proxy-server.js & vite",
    "prebuild": "node scripts/update-version.js",
    "build": "vite build",
    "preview": "vite preview",
    "android:dev": "npm run build && npx cap sync android && npx cap run android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "android:build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && electron electron/main.cjs\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:first": "commit-and-tag-version --first-release"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.970.0",
    "@capacitor-firebase/authentication": "^6.3.1",
    "@capacitor-firebase/messaging": "^6.3.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/push-notifications": "^6.0.5",
    "dotenv": "^17.2.3",
    "firebase": "^10.7.1",
    "firebase-admin": "^13.6.0",
    "lucide-react": "^0.303.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "autoprefixer": "^10.4.16",
    "commit-and-tag-version": "^12.6.1",
    "cors": "^2.8.5",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "express": "^5.2.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.3",
    "vite": "^5.0.8",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}

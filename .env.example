# Firebase Auth + FCM (mantidos pós-migração — login Google + push notifications)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Backend API (FastAPI) — todo dado e IA roda aqui
VITE_API_URL=http://localhost:8000

# REMOVIDOS pós Fase E migration:
# VITE_GOOGLE_AI_KEY            — IA roda no backend (/documents/process)
# VITE_FIREBASE_STORAGE_BUCKET  — não mais usado (R2 via backend)
# VITE_S3_ENDPOINT_URL          — credenciais R2 saíram do bundle
# VITE_S3_REGION
# VITE_S3_ACCESS_KEY_ID
# VITE_S3_SECRET_ACCESS_KEY
# VITE_S3_BUCKET_NAME
# VITE_S3_PUBLIC_URL
# VITE_S3_PATH_PREFIX
